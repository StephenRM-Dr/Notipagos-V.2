# ===== BASE DE DATOS =====
# Host de la base de datos PostgreSQL
# Ejemplo con Neon: neon-project-name.neon.tech
DB_HOST=your-db-host.neon.tech

# Nombre de la base de datos
DB_NAME=neondb

# Usuario de la base de datos
DB_USER=neonuser

# Contraseña de la base de datos (CAMBIAR INMEDIATAMENTE)
DB_PASS=your-secure-password-here

# Puerto de PostgreSQL (usualmente 5432)
DB_PORT=5432

# ===== SEGURIDAD =====
# Las siguientes claves se generan AUTOMÁTICAMENTE al iniciar la aplicación
# si no existen en el archivo .env

# Hash bcrypt de la contraseña del admin
# Se genera automáticamente con PIN por defecto: 1234
# CAMBIA EL PIN INMEDIATAMENTE después del primer inicio
ADMIN_PASSWORD_HASH=

# Clave secreta para firmar sesiones
# Se genera automáticamente (32 bytes aleatorios)
SECRET_KEY=

# Clave de encriptación Fernet para datos sensibles
# Se genera automáticamente
ENCRYPTION_KEY=

# ===== API BANCO BDV =====
# API Key proporcionada por BDV para conciliación de pagos móviles
BDV_API_KEY=96R7T1T5J2134T5YFC2GF15SDFG4BD1Z

# URL del API de producción
BDV_API_URL=https://bdvconciliacion.banvenez.com:443/getMovement

# URL del API de calidad/pruebas
BDV_API_URL_TEST=http://200.11.243.176:444/getMovement

# Ambiente: 'produccion' o 'calidad'
BDV_AMBIENTE=produccion

# ===== ENTORNO =====
# NUNCA usar 'development' en producción
FLASK_ENV=production

# NUNCA usar True en producción
DEBUG=False
